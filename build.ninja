rule cc
    command = tcc $cflags -MD -MF $out.d -c -o $out $in 
    depfile = $out.d
    description = $in

rule link
    command = tcc -o $out $in $ldflags

cflags = -g
ldflags = -lm

outdir = .build

build $outdir/string.o: cc src/string/compile.c
build $outdir/timing.o: cc src/timing/timing.c
build $outdir/main.o: cc src/main.c

build $outdir/main: link $outdir/string.o $outdir/timing.o $outdir/main.o
